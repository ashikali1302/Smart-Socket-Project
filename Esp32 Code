#include <WiFi.h>
#include <Firebase_ESP_Client.h>

// 🔹 WiFi
#define WIFI_SSID "YOUR_WIFI_NAME"
#define WIFI_PASSWORD "YOUR_WIFI_PASSWORD"

// 🔹 Firebase
#define DATABASE_URL "https://universal-smart-socket-cfcc1-default-rtdb.firebaseio.com/"

// 🔹 Pins
#define RELAY_PIN 5
#define VOLTAGE_PIN 34
#define CURRENT_PIN 35

FirebaseData fbdo;
FirebaseAuth auth;
FirebaseConfig config;

// 🔹 Variables
float voltage = 0;
float current = 0;
float power = 0;
float unit = 0;
float bill = 0;
String status = "OFF";

float cost_per_unit = 8.0;
unsigned long lastTime;

void setup() {
  Serial.begin(115200);

  pinMode(RELAY_PIN, OUTPUT);

  // 🔹 Connect WiFi
  WiFi.begin(WIFI_SSID, WIFI_PASSWORD);
  Serial.print("Connecting WiFi");
  while (WiFi.status() != WL_CONNECTED) {
    Serial.print(".");
    delay(500);
  }
  Serial.println(" Connected!");

  // 🔹 Firebase setup
  config.database_url = DATABASE_URL;
  Firebase.begin(&config, &auth);
  Firebase.reconnectWiFi(true);

  lastTime = millis();
}

void loop() {

  // 🔹 1. Read ON/OFF from Firebase
  if (Firebase.RTDB.getString(&fbdo, "/status")) {
    status = fbdo.stringData();
  }

  // 🔹 2. Relay Control
  if (status == "ON") {
    digitalWrite(RELAY_PIN, HIGH);
  } else {
    digitalWrite(RELAY_PIN, LOW);
  }

  // 🔹 3. Read Sensors
  int v_raw = analogRead(VOLTAGE_PIN);
  int c_raw = analogRead(CURRENT_PIN);

  // 🔹 4. Convert (approx)
  voltage = v_raw * (230.0 / 4095.0);
  current = (c_raw - 2048) * (5.0 / 4095.0);

  // 🔹 5. Calculate Power
  power = voltage * current;

  // 🔹 6. Time Calculation
  unsigned long now = millis();
  float time_hours = (now - lastTime) / 3600000.0;
  lastTime = now;

  // 🔹 7. Unit & Bill Calculation
  unit += (power * time_hours) / 1000.0;
  bill = unit * cost_per_unit;

  // 🔹 8. Send Data to Firebase
  Firebase.RTDB.setString(&fbdo, "/status", status);
  Firebase.RTDB.setFloat(&fbdo, "/unit", unit);
  Firebase.RTDB.setFloat(&fbdo, "/bill", bill);

  // 🔹 Debug
  Serial.println("------");
  Serial.println("Status: " + status);
  Serial.println("Voltage: " + String(voltage));
  Serial.println("Current: " + String(current));
  Serial.println("Power: " + String(power));
  Serial.println("Unit: " + String(unit));
  Serial.println("Bill: " + String(bill));

  delay(3000);
}
